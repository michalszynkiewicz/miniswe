# Dockerfile.aider — Isolated environment for running one aider variant.
#
# Mirrors Dockerfile.benchmark but installs aider-chat instead of miniswe.
# Keeps the Rust toolchain so the same 6-check validation can run in-container.
#
# Build:
#   docker build -f scripts/Dockerfile.aider -t miniswe-aider-bench .

FROM rust:1.89-bookworm

RUN apt-get update && apt-get install -y --no-install-recommends \
    pkg-config libssl-dev git curl ca-certificates python3 python3-pip \
    && rm -rf /var/lib/apt/lists/*

# aider-chat from PyPI. --break-system-packages because Debian 12's pip
# refuses to install into the system site by default; we don't care since
# this is a single-purpose container.
RUN pip3 install --no-cache-dir --break-system-packages aider-chat

WORKDIR /build

# Bring the repo in so we have a .git for `git archive ${BASELINE_SHA}`.
# Unlike the miniswe image we do NOT build a binary here — aider runs
# against the freshly-archived /work tree at execution time.
COPY . .
RUN cd /build && cargo fetch

# Keep the repo for git archive — same convention as the miniswe image.
RUN mkdir /repo && cp -r /build/.git /repo/.git

# Clean source tree — each variant starts from a fresh git-archive.
RUN rm -rf /build/target /build/src /build/tests /build/Cargo.lock 2>/dev/null || true

WORKDIR /work
